# OpenClaw HoneyAI — .gitignore
# ─────────────────────────────────────────────────
# NEVER commit secrets or generated configs

# 🔐 Private — API keys, personal config
/.env
.env.*
config.yaml
config.*.yaml           # deployment-specific configs (config.pi5.yaml, etc.)
.host_key               # persistent SSH host key

# 📁 Runtime data
logs/
*.log

# 🧪 Scratch / debug scripts
scratch/

# 🟦 Node
node_modules/
npm-debug.log*
package-lock.json

# 🍎 macOS
.DS_Store
._.DS_Store

# 💻 IDE
.vscode/
.idea/
*.swp

# 📊 Local dashboard / deployment artifacts
honey-ai/
