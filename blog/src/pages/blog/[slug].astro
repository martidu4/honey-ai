---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const severityEmoji: Record<string, string> = {
  quiet: '😴', low: '🟡', medium: '🟠', high: '🔴', critical: '💀',
};

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title={`${post.data.title} — Honeypot Threat Analysis`}
  description={post.data.description}
>
  <article class="container">
    <div class="post-header">
      <div class="meta">
        <span class="post-date">{formatDate(post.data.date)}</span>
        <span class={`severity ${post.data.severity}`}>
          {severityEmoji[post.data.severity]} {post.data.severity}
        </span>
        <span class="ai-badge">🤖 {post.data.ai_model}</span>
      </div>
      <h1>{post.data.title}</h1>
      {post.data.description && (
        <p class="post-desc">{post.data.description}</p>
      )}

      <div class="post-meta-row">
        <span>🌍 {post.data.total_ips} unique attackers</span>
        <span>⚡ {post.data.total_events.toLocaleString()} events</span>
        {post.data.report_date && (
          <a href={`/reports/${post.data.report_date}`} class="data-link">📊 View raw data report →</a>
        )}
      </div>

      {post.data.tags.length > 0 && (
        <div class="sc-tags" style="margin-top: 0.75rem;">
          {post.data.tags.map(tag => (
            <span class="sc-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <div class="prose">
      <Content />
    </div>

    <div class="post-footer">
      <div class="ai-disclaimer">
        <span>🤖</span>
        <p>
          This analysis was generated by <strong>{post.data.ai_model}</strong> running locally on the same
          Raspberry Pi 5 that operates the honeypots. No data leaves the device.
          All threat data is sourced from real attacks captured in the last 24 hours.
        </p>
      </div>
      <div class="post-nav">
        <a href="/blog" class="btn btn-outline">← All analyses</a>
        {post.data.report_date && (
          <a href={`/reports/${post.data.report_date}`} class="btn btn-outline">📊 Data report →</a>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .ai-badge {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--cyan);
    background: rgba(0, 212, 255, 0.08);
    border: 1px solid rgba(0, 212, 255, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    letter-spacing: 0.05em;
  }
  .post-desc {
    color: var(--text-dim);
    font-size: 1.05rem;
    margin-top: 0.75rem;
    max-width: 640px;
  }
  .post-meta-row {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .data-link {
    color: var(--green) !important;
  }
  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .ai-disclaimer {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: rgba(0, 212, 255, 0.04);
    border: 1px solid rgba(0, 212, 255, 0.12);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .ai-disclaimer span {
    font-size: 1.3rem;
    flex-shrink: 0;
  }
  .ai-disclaimer p {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0;
  }
  .post-nav {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
</style>
