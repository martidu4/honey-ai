---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(allPosts, { pageSize: 7 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const severityEmoji: Record<string, string> = {
  quiet: '😴', low: '🟡', medium: '🟠', high: '🔴', critical: '💀',
};

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title={`Threat Analysis Blog${page.currentPage > 1 ? ` — Page ${page.currentPage}` : ''} — AI-Powered Honeypot Intelligence`}
  description="Daily AI-generated threat analysis from HoneyAI and legacy honeypot decoys running on a Raspberry Pi 5 in Spain."
>
  <section class="section" style="padding-top: 3rem;">
    <div class="container">
      <span class="hero-badge">🤖 AI-Generated Analysis</span>
      <div class="section-title" style="font-size: 1.8rem; margin-top: 1rem;">
        Threat Analysis Blog
      </div>
      <p class="section-sub" style="max-width: 560px;">
        Daily threat intelligence analysis generated by a local AI model running on the same
        Raspberry Pi 5 that operates HoneyAI. No data leaves the device.
      </p>

      <div class="blog-list">
        {page.data.map(post => (
          <a class="blog-card" href={`/blog/${post.slug}`}>
            <div class="blog-card-header">
              <span class="blog-card-date">{formatDate(post.data.date)}</span>
              <span class={`severity ${post.data.severity}`}>
                {severityEmoji[post.data.severity]} {post.data.severity}
              </span>
            </div>
            <h3>{post.data.title}</h3>
            <p class="blog-excerpt">{post.data.description}</p>
            <div class="blog-card-meta">
              <span>🌍 {post.data.total_ips} IPs</span>
              <span>⚡ {post.data.total_events.toLocaleString()} events</span>
              <span>🤖 {post.data.ai_model}</span>
              {post.data.report_date && (
                <span class="blog-data-link">📊 Data report →</span>
              )}
            </div>
            {post.data.tags.length > 0 && (
              <div class="blog-card-tags">
                {post.data.tags.map(tag => (
                  <span class="sc-tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>

      {/* Pagination */}
      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Blog pagination">
          {page.url.prev ? (
            <a href={page.url.prev} class="pg-btn">← Newer</a>
          ) : (
            <span class="pg-btn pg-disabled">← Newer</span>
          )}

          <div class="pg-pages">
            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(num => (
              <a
                href={num === 1 ? '/blog' : `/blog/${num}`}
                class={`pg-num ${num === page.currentPage ? 'pg-active' : ''}`}
              >
                {num}
              </a>
            ))}
          </div>

          {page.url.next ? (
            <a href={page.url.next} class="pg-btn">Older →</a>
          ) : (
            <span class="pg-btn pg-disabled">Older →</span>
          )}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-decoration: none !important;
    color: inherit !important;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }
  .blog-card:hover {
    border-color: var(--green-dim);
    background: rgba(0, 255, 136, 0.03);
    transform: translateX(4px);
  }
  .blog-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .blog-card-date {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }
  .blog-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-bright);
    font-family: var(--mono);
  }
  .blog-excerpt {
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0;
  }
  .blog-card-meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
  }
  .blog-card-meta span {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .blog-data-link {
    color: var(--green) !important;
  }
  .blog-card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  /* Pagination */
  .pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }
  .pg-btn {
    font-family: var(--mono);
    font-size: 0.82rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg2);
    color: var(--text) !important;
    text-decoration: none !important;
    transition: border-color 0.2s, background 0.2s;
    width: fit-content;
  }
  .pg-btn:first-child {
    justify-self: end;
  }
  .pg-btn:last-child {
    justify-self: start;
  }
  .pg-btn:hover:not(.pg-disabled) {
    border-color: var(--green-dim);
    background: rgba(0, 255, 136, 0.05);
  }
  .pg-disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }
  .pg-pages {
    display: flex;
    gap: 0.25rem;
  }
  .pg-num {
    font-family: var(--mono);
    font-size: 0.82rem;
    width: 2.2rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg2);
    color: var(--text-dim) !important;
    text-decoration: none !important;
    transition: all 0.2s;
  }
  .pg-num:hover {
    border-color: var(--green-dim);
    color: var(--text-bright) !important;
  }
  .pg-active {
    background: var(--green) !important;
    color: var(--bg) !important;
    border-color: var(--green) !important;
    font-weight: 700;
  }
</style>
