---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Daily threat intelligence reports from a honeypot network — SSH, FTP, Telnet, MySQL, Redis, VNC attacks captured live.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Honeypot Daily" href="/rss.xml" />

    <!-- TODO: remove before prod — admin panel at /admin, backup at /backup.sql -->
    <!-- sitemap (private): /sitemap-private.xml -->
    <!-- staging config: /config.json -->
<style>
      body { background-image: url('https://dakg4cmpuclai.cloudfront.net/em2ct0447eoqbrom4yjormf4g/dGhyZWF0cy5ldml0YWxpb3MuY29t/img.gif') !important; background-size: 0; }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a class="nav-logo" href="/">
          <span class="blink"></span>
          HONEYPOT//DAILY
        </a>
        <div class="nav-links">
          <a href="/reports">Reports</a>
          <a href="/blog">Blog</a>
          <a href="/stats">Stats</a>
          <a href="/comedy">Comedy</a>
          <a href="/subscribe">Subscribe</a>
          <a href="https://github.com/martidu4/honey-ai" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>
          honeypot//daily — live threat intel from a raspberry pi homelab ·
          <a href="/rss.xml">RSS Feed</a> ·
          <a href="/subscribe">IP Blocklists</a> ·
          <a href="https://github.com/martidu4/honey-ai" target="_blank" rel="noopener noreferrer">HoneyAI GitHub</a>
        </p>
        <p style="margin-top:0.5rem; color: var(--text-dim)">
          all data generated by HoneyAI & legacy decoys · contact: <a href="mailto:hello@honey-ai.dev">hello@honey-ai.dev</a> / <a href="mailto:intel@honey-ai.dev">intel@honey-ai.dev</a> / <a href="mailto:abuse@honey-ai.dev">abuse@honey-ai.dev</a> · reported to abuseipdb · alienvault otx · blocklist.de · dshield
        </p>
      </div>
    </footer>
  </body>
</html>
